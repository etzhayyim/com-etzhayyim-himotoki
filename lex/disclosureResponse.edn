{"lexicon" 1,
 "id" "com.etzhayyim.himotoki.disclosureResponse",
 "description"
 "Response metadata recorded by himotoki_response_intake when a target replies to a request (ADR-2605302130 §3). CONSTITUTIONAL (G6, ADR-2605181100): when the response contains personal data (DSAR), the disclosed payload MUST be stored ONLY as an `com.etzhayyim.encrypted.*` XChaCha20-Poly1305 envelope DID-bound to the requesting member, referenced here via `encryptedPayloadCid`; the cleartext PII is NEVER placed inline and NEVER on plaintext MST. Public-record FOIA payloads (non-PII) may be referenced via `publicPayloadCid` and optionally fed to danjo/ossekai (G11).",
 "defs"
 {"main"
  {"type" "record",
   "key" "tid",
   "record"
   {"type" "object",
    "required" ["receivedAt" "dispatchCid" "outcome" "deadlineMet"],
    "properties"
    {"receivedAt" {"type" "string", "format" "datetime"},
     "dispatchCid"
     {"type" "string",
      "description" "CID of the requestDispatch this responds to"},
     "outcome"
     {"type" "string",
      "knownValues"
      ["full-disclosure"
       "partial-disclosure"
       "refused"
       "no-record"
       "non-response"
       "needs-clarification"],
      "description"
      "Factual response outcome (NON-adjudicating — no legal characterization here; that routes to chigiri + counsel)"},
     "deadlineMet"
     {"type" "boolean",
      "description"
      "Whether the response arrived within the statutory deadline"},
     "encryptedPayloadCid"
     {"type" "string",
      "description"
      "DSAR/PII: CID of the com.etzhayyim.encrypted.* DID-bound envelope holding the disclosed personal data (G6). MUTUALLY the only place PII lives."},
     "publicPayloadCid"
     {"type" "string",
      "description"
      "FOIA/non-PII: CID of the public-record payload (may feed danjo/ossekai)"},
     "refusalReasonText"
     {"type" "string",
      "maxLength" 2000,
      "description"
      "Verbatim refusal/partial reason as stated by the target (no editorial legal conclusion)"},
     "appealEligible"
     {"type" "boolean",
      "description"
      "Whether a statutory appeal path exists (routes to himotoki_appeal_route)"}}}}}}
