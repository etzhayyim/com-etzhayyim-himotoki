  "constitutionalGates": {
    "description": "14 immutable gates per ADR-2605302130 §4. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every authored artifact + dispatch",
      "G2": "kotoba attestation lineage on every record",
      "G3": "Consent-gated + identity-bound — DSAR is member-initiated, consent + Adherent-SBT/DID bound, OWN data only; never a third party's PII; never a non-consenting person",
      "G4": "Transparent + non-pretextual — true requester always identified; no sockpuppet / pretext / impersonation / social-engineering (§2(c))",
      "G5": "UPL-equivalent — files + tracks; no legal advice; characterization + appeal strategy via chigiri + external counsel (Public Fund)",
      "G6": "PII confidentiality mandatory — disclosed personal data ONLY in com.etzhayyim.encrypted.* DID-bound envelopes (ADR-2605181100); never plaintext PII on MST",
      "G7": "Murakumo-only inference (ADR-2605215000)",
      "G8": "Rate-limited / non-vexatious — no mass-filing / bulk enumeration / request-flooding; per-target + per-member rate caps",
      "G9": "No data-broker / no pretext-as-a-service — no resale of disclosed data; non-profit + member-benefit only",
      "G10": "Lawful-channel-only — only external mutation is a lawful request through an official channel; never alters target records; never unauthorized access / access-control circumvention",
      "G11": "Transparent Religious Force discipline (§1.12) — request + tracking + intake ONLY; no coercion; lawful appeal channels; 1 SBT = 1 vote governs FOIA public-record aggregate publication",
      "G12": "Scope-minimization / data-minimization — request only what is needed; no fishing expeditions",
      "G13": "stateAlignedFlag pass-through — CN-class / state-aligned targets carry the flag into derived records",
      "G14": "Verified-target-only dispatch — himotoki_dispatch refuses unverified-seed / stale targets; live filing requires maintainer-verified (FOIA) / council-verified (named controller / DSAR)"
    }
  },
  "nonGoals": {
    "description": "13 explicitly excluded scopes",
    "goals": {
      "N1": "NOT a law firm / litigation arm (UPL)",
      "N2": "NOT a private-investigator / people-search (cannot request OTHERS' personal data)",
      "N3": "NOT a surveillance / dossier-building system",
      "N4": "NOT a data-broker / reseller of disclosed data",
      "N5": "NOT a pretext / social-engineering / impersonation tool",
      "N6": "NOT an unauthorized-access / hacking / access-control-circumvention / scrape-around tool",
      "N7": "NOT a mass-filing / request-flooding / agency-DoS tool",
      "N8": "NOT a state-granted legal personality",
      "N9": "NOT a closed-source / secret-method engine",
      "N10": "NOT a replacement for the member's own direct right (assists, does not supplant)",
      "N11": "NOT a plaintext-PII store",
      "N12": "NOT Japan-exclusive in architecture (JP-first at R0; jurisdiction-generic)",
      "N13": "NOT a re-disclosure / leak channel (disclosed PII for the requesting member only)"
    }
  },
